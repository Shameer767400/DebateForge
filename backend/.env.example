# ── Database ──
MONGODB_URI=mongodb://localhost:27017/debateforge

# ── Server ──
PORT=5001

# ── Cache (optional — app falls back to in-memory store if Redis is unavailable) ──
REDIS_URL=redis://localhost:6379

# ── Auth ──
JWT_SECRET=your_super_secret_key_here

# ── AI — use one of: Gemini (recommended free tier) or OpenAI ──
GEMINI_API_KEY=your_gemini_api_key_here
OPENAI_API_KEY=your_openai_api_key_here   # optional, fallback

# ── ElevenLabs TTS (optional — app uses browser Web Speech API if omitted) ──
ELEVENLABS_API_KEY=your_elevenlabs_api_key_here
ELEVENLABS_VOICE_ID=your_voice_id_here

# ── ML microservice ──
ML_SERVICE_URL=http://localhost:8001

# ── CORS — comma-separated list of allowed frontend origins ──
FRONTEND_URL=http://localhost:3000
